@model BudgetTracker.ViewModels.History.DetailsViewModel;
@using System.Text.Json

@{
    string mes = new DateTime(1, Model.Month, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-AR"));

    var labelsIngresos = JsonSerializer.Serialize(Model.CategoriesIncomes?.Select(c => c.CategoryName) ?? Array.Empty<string>());
    var datosIngresos = JsonSerializer.Serialize(Model.CategoriesIncomes?.Select(c => c.TotalIncome) ?? Array.Empty<decimal>());

    var labelsGastos = JsonSerializer.Serialize(Model.CategoriesBills?.Select(c => c.CategoryName) ?? Array.Empty<string>());
    var datosGastos = JsonSerializer.Serialize(Model.CategoriesBills?.Select(c => c.TotalBill) ?? Array.Empty<decimal>());
}

<div class="d-flex flex-column justify-content-center align-items-center">
    <div class="d-flex flex-row justify-content-center align-items-center p-2">
        <a asp-controller="History" asp-action="GetBillIncomeAndMonthlyTotal" asp-route-month="@Model.Month" asp-route-year="@Model.Year" class="btn text-white me-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="1.1vw" height="1.1vw" fill="currentColor" class="bi bi-arrow-left-circle-fill" viewBox="0 0 16 16">
                <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0m3.5 7.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5z" />
            </svg>
        </a>
        <h1>Detalles del mes @(char.ToUpper(mes[0]) + mes.Substring(1)) - @Model.Year.ToString("D4")</h1>
    </div>

    <div class="d-flex flex-column justify-content-center align-items-center border rounded box-shadow p-4 bg-secondary center">
        <div class="d-flex flex-column justify-content-center align-items-center pt-2 pb-2">
            <div class="d-flex flex-row justify-content-center align-items-center">
                <h2>
                    Total de ingresos: @(Model.TotalIncome.ToString("C")) -
                    Total de gastos: @(Model.TotalBill.ToString("C"))
                </h2>
            </div>

            <div>
                <h2>
                    Total del mes: @((Model.TotalIncome - Model.TotalBill).ToString("C", new System.Globalization.CultureInfo("es-AR")))
                </h2>
            </div>
        </div>

        <div class="d-flex flex-row" style="width: 85vw;">
            <table class="table table-bordered text-center" style="width: 58vw;">
                <thead>
                    <tr>
                        <th style="width: 6vw">Fecha</th>
                        <th style="width: 40vw">Descripción</th>
                        <th style="width: 5vw">Tipo</th>
                        <th style="width: 10vw">Categoria</th>
                        <th style="width: 10vw">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions != null && Model.Transactions.Any())
                    {
                        @for (var numDay = 1; numDay <= DateTime.DaysInMonth(Model.Year, Model.Month); numDay++)
                        {
                            var currentDate = new DateOnly(Model.Year, Model.Month, numDay);
                        
                            @if (Model.Transactions.Any(t => t.Date == currentDate))
                            {
                                @foreach (var transaction in Model.Transactions.Where(t => t.Date == currentDate))
                                {
                                    <tr>
                                        <td style="width: 6vw">@transaction.Date.ToString("dd/MM/yyyy")</td>
                                        <td style="width: 40vw">@transaction.Description</td>
                                        <td style="width: 5vw">@transaction.Type</td>
                                        <td style="width: 10vw">@transaction.Category</td>
                                        <td style="width: 10vw">@transaction.Amount.ToString("C")</td>
                                    </tr>
                                }
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td class="text-black" colspan="5">No hay entradas para este mes.</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex flex-row justify-content-between ps-4" style="width: 27vw;">
                <div class="d-flex flex-column align-items-center" style="width: 12.5vw;">
                    <p class="text-center text-black mb-0 pb-0 border-bottom-0 border-top border-start border-end" style="width: 100%;">
                        <strong>Ingresos</strong>
                    </p>
                    <table class="table table-bordered text-center" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>Categoria</th>
                                <th>Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.CategoriesIncomes != null && Model.CategoriesIncomes.Any())
                            {
                                @foreach (var category in Model.CategoriesIncomes)
                                {
                                    <tr>
                                        <td>@category.CategoryName</td>
                                        <td>@category.TotalIncome.ToString("C")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td class="text-black" colspan="2">No hay ingresos para este mes.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <p class="text-center text-black mb-0 pb-0 border-bottom-0 border-top border-start border-end pt-1" style="width: 100%;">
                        <strong>Gastos</strong>
                    </p>
                    <table class="table table-bordered text-center" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>Categoria</th>
                                <th>Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.CategoriesBills != null && Model.CategoriesBills.Any())
                            {
                                @foreach (var category in Model.CategoriesBills)
                                {
                                    <tr>
                                        <td>@category.CategoryName</td>
                                        <td>@category.TotalBill.ToString("C")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td class="text-black" colspan="2">No hay gastos para este mes.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex flex-column justify-content-center align-items-center" style="height: 32vh; width: 12.5vw;">
                    @if (Model.CategoriesIncomes != null && Model.CategoriesIncomes.Any())
                    {
                        <div class="d-flex flex-column align-items-center mb-2" style="height: 16vh; width: 100%; max-width: 12.5vw;">
                            <p class="mb-0"><strong>Distribucion de Ingreso</strong></p>
                            <div style="position: relative; width: 100%; height: 16vh;">
                                <canvas id="chartIngresos" style="width: 100%; height: 100%;"></canvas>
                            </div>
                        </div>
                    }

                    @if (Model.CategoriesBills != null && Model.CategoriesBills.Any())
                    {
                        <div class="d-flex flex-column align-items-center" style="height: 16vh; width: 100%; max-width: 12.5vw;">
                            <p class="mb-0"><strong>Distribucion de Gastos</strong></p>
                            <div style="position: relative; width: 100%; height: 16vh;">
                                <canvas id="chartGastos" style="width: 100%; height: 100%;"></canvas>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        
        const canvasIngresos = document.getElementById('chartIngresos');
        if (canvasIngresos) {
            const ctxIngresos = canvasIngresos.getContext('2d');
            new Chart(ctxIngresos, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(labelsIngresos),
                    datasets: [{
                        data: @Html.Raw(datosIngresos),
                        backgroundColor: ['#2ecc71', '#27ae60', '#16a085', '#1abc9c', '#3498db'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            maxHeight: 60,
                            labels: {
                                color: 'black',
                                font: {
                                    size: 18,
                                    weight: 'bold'
                                },
                                boxWidth: 16,
                                boxHeight: 16,
                                padding: 8
                            }
                        }
                    },
                    layout: {
                        padding: {
                            top: 0,
                            bottom: 0
                        }
                    },
                    radius: '90%',
                    cutout: '30%'
                }
            });
        }

        const canvasGastos = document.getElementById('chartGastos');
        if (canvasGastos) {
            const ctxGastos = canvasGastos.getContext('2d');
            new Chart(ctxGastos, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(labelsGastos),
                    datasets: [{
                        data: @Html.Raw(datosGastos),
                        backgroundColor: ['#e74c3c', '#c0392b', '#e67e22', '#d35400', '#f1c40f'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            maxHeight: 60,
                            labels: {
                                color: 'black',
                                font: {
                                    size: 18,
                                    weight: 'bold'
                                },
                                boxWidth: 16,
                                boxHeight: 16,
                                padding: 8
                            }
                        }
                    },
                    layout: {
                        padding: {
                            top: 0,
                            bottom: 0
                        }
                    },
                    radius: '90%',
                    cutout: '30%'
                }
            });
        }
    });
    </script>
}