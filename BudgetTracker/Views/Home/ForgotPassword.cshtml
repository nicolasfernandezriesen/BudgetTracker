<div class="d-flex flex-column justify-content-center align-items-center">

    <div class="d-flex justify-content-evenly align-items-center p-2" style="max-width: 75%; min-width: 50%;">
        <a asp-controller="Home" asp-action="Index" class="btn text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="1.1vw" height="1.1vw" fill="currentColor" class="bi bi-arrow-left-circle-fill" viewBox="0 0 16 16">
                <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0m3.5 7.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5z" />
            </svg>
        </a>
        <h1 class="m-4">Recuperacion de contraseña</h1>
    </div>

    <div class="border rounded box-shadow p-4 bg-secondary" style="width: 20vw;">
        <form id="forgotPasswordForm" asp-action="ForgotPassword" asp-controller="Home" method="post" class="d-flex flex-column align-items-center justify-content-center">
            <div class="d-flex flex-row mb-3" style="width: 100%;">
                <label class="col-sm-2 col-form-label">Email:</label>
                <input type="email" id="email" name="email" placeholder="Ingresa tu email" class="form-control" />
            </div>

            <button type="button" class="btn btn-primary mt-2" onclick="forgotPassword()">Recuperar contraseña</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/Home/ForgotPassword.js" asp-append-version="true"></script>
}