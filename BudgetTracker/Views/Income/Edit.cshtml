@model BudgetTracker.ViewModels.Income.EditViewModel

<div class="d-flex flex-column justify-content-center align-items-center" style="height: 65vh;">

    <div class="d-flex justify-content-center align-items-center p-2" style="max-width: 75%; min-width: 30%;">
        <h1>Editar Ingreso</h1>
    </div>

    <div class="border  rounded box-shadow p-4 m-4 bg-secondary center" style="max-width: 75%; min-width: 25%;">
        <form asp-controller="Income" asp-action="Edit" id="editIncomeForm">
            <div class="p-2">
                <div class="form-group text-center">
                    <label asp-for="IncomeAmount" class="form-label pb-1">Monto del ingreso: </label><br />
                    <input asp-for="IncomeAmount" class="form-control text-center" type="number" name="IncomeAmount" value="@Model.IncomeAmount" min="0" style="max-width: 10vw; display:inline;" required />
                </div>
                <div class="form-group text-center">
                    <label asp-for="CategoryId" class="form-label pt-2 pb-1">Categoria (Seleccionar uno): </label>
                    <div class="d-flex flex-wrap m-auto" style="max-width: 60%;">
                        <select id="category-select" asp-for="CategoryId" name="CategoryId" class="form-control" placeholder="Selecciona o busca...">
                            <option value="">Buscar categoría...</option>
        
                            @foreach (var group in Model.AvailableCategories)
                            {
                                <optgroup label="@group.GroupName">
                                    @foreach (var sub in group.SubCategories)
                                    {
                                        <option value="@sub.CategoryId" >@sub.CategoryName</option>
                                    }
                                </optgroup>
                            }
                        </select>
                </div>
                <div class="form-group text-center">
                    <label asp-for="IncomeDesc" class="form-label pt-2 pb-1">Descripcion (opcional): </label>
                    <textarea asp-for="IncomeDesc" class="form-control" name="IncomeDesc" value="@Model.IncomeDesc"></textarea>
                </div>
                <div class="form-group pt-2 text-center">
                    <label asp-for="IncomeDate" class="form-label pt-2 pb-1 pe-4">Fecha: </label><br />
                    <input asp-for="IncomeDate" type="date" name="IncomeDate" class="form-control text-center" style="max-width: 10vw; display:inline;" min="@DateTime.Now.AddMonths(-2).ToString("yyyy-MM-dd")" max="@DateTime.Now.AddMonths(2).ToString("yyyy-MM-dd")" required />
                </div>
            </div>
            <input type="hidden" name="IncomeId" value="@Model.IncomeId" />
            <div class="d-flex justify-content-evenly align-items-center pt-2">
                <button type="button" class="btn btn-danger" onclick="Cancel()">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="SaveEdit()">Guardar ingreso</button>
            </div>
        </form>
    </div>
</div>

<div id="incomeDate" data-income-date="@Model.IncomeDate.ToString("yyyy-MM-dd")"></div>

@section Scripts {
    <script src="~/js/Income/Edit.js" asp-append-version="true"></script>
        <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

        <script>
            new TomSelect("#category-select", {
            create: false,
            sortField: { field: "text", direction: "asc" },
            placeholder: "Escribe para buscar...",
            plugins: ['dropdown_input']
            });
        </script>
}